<!-- KPI Cards -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="kpi-card">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <p class="text-muted small mb-1">Total clients</p>
          <h3 class="fw-bold mb-0"><%= stats.totalClients %></h3>
          <small class="text-success"><%= stats.activeClients %> actifs</small>
        </div>
        <div class="kpi-icon" style="background:#eff6ff">
          <i class="bi bi-people-fill text-primary"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="kpi-card">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <p class="text-muted small mb-1">Total transactions</p>
          <h3 class="fw-bold mb-0"><%= stats.totalTransactions %></h3>
          <small class="text-muted"><%= stats.depositCount + stats.withdrawCount %> (7 derniers jours)</small>
        </div>
        <div class="kpi-icon" style="background:#f0fdf4">
          <i class="bi bi-arrow-left-right text-success"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="kpi-card">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <p class="text-muted small mb-1">Volume dépôts</p>
          <h3 class="fw-bold mb-0" style="font-size:1.1rem"><%= stats.totalDeposits.toLocaleString('fr-FR') %></h3>
          <small class="text-muted">FCFA</small>
        </div>
        <div class="kpi-icon" style="background:#f0fdf4">
          <i class="bi bi-arrow-down-circle-fill text-success"></i>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="kpi-card">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <p class="text-muted small mb-1">Fonds en circulation</p>
          <h3 class="fw-bold mb-0" style="font-size:1.1rem"><%= stats.totalBalance.toLocaleString('fr-FR') %></h3>
          <small class="text-muted">FCFA dans tous les comptes</small>
        </div>
        <div class="kpi-icon" style="background:#fefce8">
          <i class="bi bi-wallet2 text-warning"></i>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Charts -->
<div class="row g-3 mb-4">
  <div class="col-md-8">
    <div class="chart-card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Activité des 7 derniers jours</h6>
        <div class="d-flex gap-3 small text-muted">
          <span><span style="display:inline-block;width:10px;height:10px;background:#22c55e;border-radius:2px;margin-right:4px"></span>Dépôts</span>
          <span><span style="display:inline-block;width:10px;height:10px;background:#f97316;border-radius:2px;margin-right:4px"></span>Retraits</span>
        </div>
      </div>
      <canvas id="activityChart" height="100"></canvas>
    </div>
  </div>
  <div class="col-md-4">
    <div class="chart-card h-100 d-flex flex-column">
      <h6 class="fw-semibold mb-3">Répartition des opérations</h6>
      <div class="flex-grow-1 d-flex align-items-center justify-content-center">
        <div style="max-width:200px;width:100%">
          <canvas id="pieChart"></canvas>
        </div>
      </div>
      <div class="mt-3 d-flex justify-content-around text-center">
        <div>
          <div class="fw-bold text-success"><%= stats.depositCount %></div>
          <small class="text-muted">Dépôts</small>
        </div>
        <div>
          <div class="fw-bold text-warning"><%= stats.withdrawCount %></div>
          <small class="text-muted">Retraits</small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent tables -->
<div class="row g-3">
  <div class="col-md-7">
    <div class="chart-card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Dernières transactions</h6>
        <a href="/admin/transactions" class="btn btn-sm btn-outline-primary">Voir tout</a>
      </div>
      <% if (stats.recentTransactions.length === 0) { %>
        <p class="text-muted text-center py-3">Aucune transaction pour le moment</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light"><tr><th>Client</th><th>Opération</th><th>Montant</th><th>Date</th></tr></thead>
            <tbody>
              <% stats.recentTransactions.forEach(tx => { %>
                <tr>
                  <td class="fw-semibold small"><%= tx.user ? tx.user.name : '—' %></td>
                  <td>
                    <span class="badge <%= tx.type === 'deposit' ? 'bg-success' : 'bg-warning text-dark' %>">
                      <%= tx.type === 'deposit' ? 'Dépôt' : 'Retrait' %>
                    </span>
                  </td>
                  <td class="fw-semibold small <%= tx.type === 'deposit' ? 'text-success' : 'text-warning' %>">
                    <%= tx.type === 'deposit' ? '+' : '-' %><%= parseFloat(tx.amount).toLocaleString('fr-FR') %> FCFA
                  </td>
                  <td class="text-muted small"><%= new Date(tx.createdAt).toLocaleDateString('fr-FR') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
  <div class="col-md-5">
    <div class="chart-card">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Nouveaux clients</h6>
        <a href="/admin/users" class="btn btn-sm btn-outline-primary">Voir tout</a>
      </div>
      <% if (stats.recentClients.length === 0) { %>
        <p class="text-muted text-center py-3">Aucun client enregistré</p>
      <% } else { %>
        <% stats.recentClients.forEach(client => { %>
          <div class="d-flex align-items-center gap-3 py-2 border-bottom">
            <div style="width:36px;height:36px;background:#eff6ff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;color:#2563eb;font-size:0.85rem;flex-shrink:0">
              <%= client.name.charAt(0).toUpperCase() %>
            </div>
            <div class="flex-grow-1 overflow-hidden">
              <div class="fw-semibold small text-truncate"><%= client.name %></div>
              <div class="text-muted" style="font-size:0.75rem"><%= client.email %></div>
            </div>
            <div class="text-end">
              <div class="fw-semibold small"><%= parseFloat(client.balance).toLocaleString('fr-FR') %></div>
              <div class="text-muted" style="font-size:0.7rem">FCFA</div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<script>
const chartLabels = <%- JSON.stringify(stats.chartLabels) %>;
const chartDeposits = <%- JSON.stringify(stats.chartDeposits) %>;
const chartWithdrawals = <%- JSON.stringify(stats.chartWithdrawals) %>;

// Bar chart — activité 7 jours
const ctx1 = document.getElementById('activityChart').getContext('2d');
new Chart(ctx1, {
  type: 'bar',
  data: {
    labels: chartLabels,
    datasets: [
      {
        label: 'Dépôts (FCFA)',
        data: chartDeposits,
        backgroundColor: 'rgba(34,197,94,0.7)',
        borderColor: '#22c55e',
        borderWidth: 1,
        borderRadius: 5,
      },
      {
        label: 'Retraits (FCFA)',
        data: chartWithdrawals,
        backgroundColor: 'rgba(249,115,22,0.7)',
        borderColor: '#f97316',
        borderWidth: 1,
        borderRadius: 5,
      }
    ]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
      x: { grid: { display: false } },
      y: {
        beginAtZero: true,
        ticks: {
          callback: v => v.toLocaleString('fr-FR') + ' F'
        }
      }
    }
  }
});

// Doughnut chart
const ctx2 = document.getElementById('pieChart').getContext('2d');
const depTotal = chartDeposits.reduce((a,b) => a+b, 0);
const witTotal = chartWithdrawals.reduce((a,b) => a+b, 0);
new Chart(ctx2, {
  type: 'doughnut',
  data: {
    labels: ['Dépôts', 'Retraits'],
    datasets: [{
      data: [depTotal || 1, witTotal || 1],
      backgroundColor: ['#22c55e', '#f97316'],
      borderWidth: 0,
    }]
  },
  options: {
    cutout: '70%',
    plugins: {
      legend: { display: false },
      tooltip: {
        callbacks: {
          label: ctx => ctx.label + ' : ' + ctx.raw.toLocaleString('fr-FR') + ' FCFA'
        }
      }
    }
  }
});
</script>
