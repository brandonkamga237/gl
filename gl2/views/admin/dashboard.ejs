<!-- KPIs -->
<div class="kpi">
  <div class="kpi-item">
    <div class="label">Clients actifs</div>
    <div class="value" style="color:#6366f1"><%= stats.activeClients %></div>
    <div class="sub"><%= stats.totalClients %> au total</div>
  </div>
  <div class="kpi-item">
    <div class="label">Dépôts (7 jours)</div>
    <div class="value" style="color:var(--green)"><%= parseFloat(stats.weekDeposits||0).toLocaleString('fr-FR') %></div>
    <div class="sub">FCFA</div>
  </div>
  <div class="kpi-item">
    <div class="label">Retraits (7 jours)</div>
    <div class="value" style="color:var(--orange)"><%= parseFloat(stats.weekWithdrawals||0).toLocaleString('fr-FR') %></div>
    <div class="sub">FCFA</div>
  </div>
  <div class="kpi-item">
    <div class="label">Opérations totales</div>
    <div class="value"><%= stats.totalTransactions %></div>
    <div class="sub">toutes périodes</div>
  </div>
</div>

<!-- Charts -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;margin-bottom:1.5rem">
  <div class="card">
    <div style="font-weight:600;font-size:.9rem;margin-bottom:1rem">Activité des 7 derniers jours</div>
    <canvas id="barChart" height="120"></canvas>
  </div>
  <div class="card">
    <div style="font-weight:600;font-size:.9rem;margin-bottom:1rem">Répartition</div>
    <canvas id="donutChart" height="170"></canvas>
    <div style="display:flex;justify-content:center;gap:1.5rem;margin-top:.75rem;font-size:.78rem;color:var(--muted)">
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#10b981;margin-right:4px"></span>Dépôts</span>
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#f59e0b;margin-right:4px"></span>Retraits</span>
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#6366f1;margin-right:4px"></span>Virements</span>
    </div>
  </div>
</div>

<!-- Recent transactions -->
<div class="card">
  <div style="font-weight:600;font-size:.9rem;margin-bottom:1rem">Dernières opérations</div>
  <% if (!recentTx || recentTx.length === 0) { %>
    <div style="text-align:center;padding:2rem;color:var(--muted)">Aucune opération</div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Type</th>
            <th>Client</th>
            <th>Montant</th>
            <th>Solde après</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% const labels = {deposit:'Dépôt',withdraw:'Retrait',transfer_out:'Virement émis',transfer_in:'Virement reçu'};
             const badgeCls = {deposit:'badge-green',withdraw:'badge-orange',transfer_out:'badge-blue',transfer_in:'badge-green'};
          %>
          <% recentTx.forEach(tx => { %>
            <tr>
              <td><span class="badge <%= badgeCls[tx.type] || 'badge-blue' %>"><%= labels[tx.type] || tx.type %></span></td>
              <td><%= tx.user ? tx.user.name : '—' %></td>
              <td style="font-weight:600"><%= parseFloat(tx.amount).toLocaleString('fr-FR') %> FCFA</td>
              <td style="color:var(--muted)"><%= parseFloat(tx.balanceAfter).toLocaleString('fr-FR') %> FCFA</td>
              <td style="color:var(--muted)"><%= new Date(tx.createdAt).toLocaleDateString('fr-FR',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
const labels = <%- JSON.stringify(stats.chartLabels || []) %>;
const deposits = <%- JSON.stringify(stats.chartDeposits || []) %>;
const withdrawals = <%- JSON.stringify(stats.chartWithdrawals || []) %>;
const totalDep = deposits.reduce((a,b)=>a+b,0);
const totalWith = withdrawals.reduce((a,b)=>a+b,0);
const totalVir = <%- stats.totalTransfers || 0 %>;

Chart.defaults.color = '#5a6e96';
Chart.defaults.borderColor = '#192540';

new Chart(document.getElementById('barChart'), {
  type: 'bar',
  data: {
    labels,
    datasets: [
      { label:'Dépôts', data:deposits, backgroundColor:'rgba(16,185,129,.7)', borderRadius:5 },
      { label:'Retraits', data:withdrawals, backgroundColor:'rgba(245,158,11,.6)', borderRadius:5 }
    ]
  },
  options: {
    responsive:true,
    plugins:{ legend:{ labels:{ boxWidth:10, padding:16 } } },
    scales:{
      x:{ grid:{ color:'rgba(255,255,255,.04)' } },
      y:{ grid:{ color:'rgba(255,255,255,.04)' }, ticks:{ callback: v => v.toLocaleString('fr-FR') } }
    }
  }
});

new Chart(document.getElementById('donutChart'), {
  type: 'doughnut',
  data: {
    labels:['Dépôts','Retraits','Virements'],
    datasets:[{ data:[totalDep||1, totalWith||1, totalVir||1], backgroundColor:['#10b981','#f59e0b','#6366f1'], borderWidth:0, hoverOffset:4 }]
  },
  options:{ responsive:true, cutout:'70%', plugins:{ legend:{ display:false } } }
});
</script>
