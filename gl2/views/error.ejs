<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Erreur · NeoBank</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#080e1c;color:#f0f4ff;font-family:'Inter',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center}
    .wrap{text-align:center;padding:2rem;max-width:420px}
    .code{font-size:5rem;font-weight:800;line-height:1;background:linear-gradient(135deg,#6366f1,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    h1{font-size:1.3rem;font-weight:700;margin:.75rem 0 .5rem}
    p{color:#5a6e96;font-size:.9rem;line-height:1.6}
    .btn{display:inline-flex;align-items:center;gap:8px;margin-top:2rem;background:#6366f1;color:#fff;border:none;border-radius:10px;padding:.7rem 1.4rem;font-weight:600;font-size:.9rem;cursor:pointer;text-decoration:none;transition:all .2s;font-family:'Inter',sans-serif}
    .btn:hover{background:#4f46e5;box-shadow:0 4px 20px rgba(99,102,241,.3)}
  </style>
</head>
<body>
<div class="wrap">
  <div class="code"><%= code || status || 500 %></div>
  <h1><%= title || (code === 404 ? 'Page introuvable' : 'Une erreur est survenue') %></h1>
  <p><%= message || 'Quelque chose s\'est mal passé. Veuillez réessayer.' %></p>
  <a href="javascript:history.back()" class="btn"><i class="bi bi-arrow-left"></i> Retour</a>
</div>
</body>
</html>
