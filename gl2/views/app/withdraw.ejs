<div class="page-header">
  <h1><i class="bi bi-arrow-up-circle" style="color:var(--orange);margin-right:.5rem"></i>Retrait</h1>
  <p>Retirez des fonds de votre compte</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i><%= error %></div>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><i class="bi bi-check-circle"></i><%= success %></div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem">

  <div class="card">
    <form method="POST" action="/app/withdraw">
      <div class="form-group">
        <label class="form-label">Montant</label>
        <div class="input-suffix">
          <input type="number" name="amount" class="form-input form-input-lg" placeholder="0" min="100" step="100" required />
          <span>FCFA</span>
        </div>
        <div class="quick-amounts">
          <span class="quick-chip" onclick="setAmt(5000)">5 000</span>
          <span class="quick-chip" onclick="setAmt(10000)">10 000</span>
          <span class="quick-chip" onclick="setAmt(25000)">25 000</span>
          <span class="quick-chip" onclick="setAmt(50000)">50 000</span>
          <span class="quick-chip" onclick="setAmt(100000)">100 000</span>
          <span class="quick-chip" onclick="setAll()">Tout retirer</span>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Description <span style="font-weight:400;text-transform:none;letter-spacing:0">(optionnel)</span></label>
        <input type="text" name="description" class="form-input" placeholder="Motif du retrait..." maxlength="120" />
      </div>
      <button type="submit" class="btn btn-orange btn-block" style="margin-top:.5rem">
        <i class="bi bi-check-lg"></i> Confirmer le retrait
      </button>
    </form>
  </div>

  <div>
    <div class="card" style="margin-bottom:1rem">
      <div style="font-size:.75rem;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:.5rem">Solde disponible</div>
      <div style="font-size:1.9rem;font-weight:800;" id="balance-display"><%= parseFloat(balance).toLocaleString('fr-FR') %></div>
      <div style="font-size:.85rem;color:var(--text3);margin-top:.25rem">FCFA</div>
    </div>
    <div class="card" style="background:rgba(245,158,11,.05);border-color:rgba(245,158,11,.15)">
      <div style="font-size:.82rem;color:var(--text2);line-height:1.7">
        <i class="bi bi-exclamation-circle" style="color:var(--orange)"></i>
        Le montant du retrait ne peut pas dépasser votre solde disponible.
      </div>
    </div>
  </div>
</div>

<script>
const bal = <%= parseFloat(balance) %>;
function setAmt(v){document.querySelector('input[name="amount"]').value=v}
function setAll(){document.querySelector('input[name="amount"]').value=bal}
</script>
