<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NeoBank</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{
      background:#080e1c;color:#f0f4ff;font-family:'Inter',sans-serif;
      min-height:100vh;display:flex;align-items:center;justify-content:center;
      background-image:radial-gradient(ellipse at 20% 50%,rgba(99,102,241,.08) 0%,transparent 60%),
                       radial-gradient(ellipse at 80% 20%,rgba(168,85,247,.06) 0%,transparent 50%);
    }
    .wrapper{width:100%;max-width:420px;padding:1.5rem}
    .logo{text-align:center;margin-bottom:2rem}
    .logo-icon{
      width:56px;height:56px;background:linear-gradient(135deg,#6366f1,#a855f7);
      border-radius:16px;display:flex;align-items:center;justify-content:center;
      font-size:1.5rem;margin:0 auto .75rem;
      box-shadow:0 0 30px rgba(99,102,241,.3);
    }
    .logo h1{font-size:1.6rem;font-weight:800;letter-spacing:-1px}
    .logo p{color:#5a6e96;font-size:.875rem;margin-top:.2rem}

    .tabs{display:flex;background:#0d1523;border:1px solid #192540;border-radius:12px;padding:4px;margin-bottom:1.5rem}
    .tab{flex:1;text-align:center;padding:.55rem;border-radius:9px;font-size:.88rem;font-weight:600;cursor:pointer;color:#5a6e96;transition:all .2s}
    .tab.active{background:#1a2540;color:#f0f4ff;box-shadow:0 2px 8px rgba(0,0,0,.3)}

    .card{background:#0d1523;border:1px solid #192540;border-radius:16px;padding:1.75rem}
    .form-group{margin-bottom:1rem}
    .form-label{display:block;font-size:.78rem;font-weight:600;color:#5a6e96;margin-bottom:.45rem;text-transform:uppercase;letter-spacing:.5px}
    .input-wrap{position:relative}
    .input-wrap i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#3a4e70;font-size:1rem}
    .form-input{
      width:100%;background:#060b14;border:1px solid #192540;
      border-radius:10px;padding:.7rem .9rem .7rem 2.5rem;
      color:#f0f4ff;font-size:.9rem;font-family:'Inter',sans-serif;outline:none;transition:border-color .15s;
    }
    .form-input:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.15)}
    .form-input::placeholder{color:#3a4e70}

    .btn-submit{
      width:100%;background:linear-gradient(135deg,#6366f1,#4f46e5);
      border:none;border-radius:10px;padding:.8rem;
      color:#fff;font-weight:700;font-size:.95rem;cursor:pointer;
      font-family:'Inter',sans-serif;letter-spacing:.2px;
      transition:all .2s;margin-top:.5rem;
      box-shadow:0 4px 20px rgba(99,102,241,.3);
    }
    .btn-submit:hover{box-shadow:0 6px 28px rgba(99,102,241,.5);transform:translateY(-1px)}

    .alert{
      border-radius:10px;padding:.75rem 1rem;margin-bottom:1rem;
      display:flex;align-items:center;gap:.6rem;font-size:.85rem;
    }
    .alert-error{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25);color:#fca5a5}
    .alert-success{background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.25);color:#6ee7b7}
    .divider{text-align:center;color:#3a4e70;font-size:.8rem;margin:.5rem 0}
    .hint{font-size:.78rem;color:#3a4e70;text-align:center;margin-top:1rem}
    .hint a{color:#6366f1}
  </style>
</head>
<body>
<div class="wrapper">
  <div class="logo">
    <div class="logo-icon"><i class="bi bi-bank2"></i></div>
    <h1>NeoBank</h1>
    <p>Votre banque numérique</p>
  </div>

  <div class="tabs">
    <div class="tab <%= mode==='login'?'active':'' %>" onclick="location.href='/login'">Connexion</div>
    <div class="tab <%= mode==='register'?'active':'' %>" onclick="location.href='/register'">Inscription</div>
  </div>

  <div class="card">
    <% if (error) { %>
      <div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && !error) { %>
      <% const s = new URLSearchParams(require('url').parse(require('url').format({query:{success:''}})).query).get('success') %>
    <% } %>

    <% if (mode === 'login') { %>
      <form method="POST" action="/login">
        <div class="form-group">
          <label class="form-label">Adresse email</label>
          <div class="input-wrap">
            <i class="bi bi-envelope"></i>
            <input type="email" name="email" class="form-input" placeholder="votre@email.com" required autocomplete="email" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Mot de passe</label>
          <div class="input-wrap">
            <i class="bi bi-lock"></i>
            <input type="password" name="password" class="form-input" placeholder="••••••••" required />
          </div>
        </div>
        <button type="submit" class="btn-submit">Se connecter <i class="bi bi-arrow-right"></i></button>
      </form>
      <p class="hint">Pas encore de compte ? <a href="/register">Créer un compte</a></p>
    <% } else { %>
      <form method="POST" action="/register">
        <div class="form-group">
          <label class="form-label">Nom complet</label>
          <div class="input-wrap">
            <i class="bi bi-person"></i>
            <input type="text" name="name" class="form-input" placeholder="Jean Dupont" required minlength="2" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Adresse email</label>
          <div class="input-wrap">
            <i class="bi bi-envelope"></i>
            <input type="email" name="email" class="form-input" placeholder="votre@email.com" required />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Téléphone <span style="color:#3a4e70;font-weight:400">(optionnel)</span></label>
          <div class="input-wrap">
            <i class="bi bi-phone"></i>
            <input type="tel" name="phone" class="form-input" placeholder="+237 6XX XXX XXX" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Mot de passe</label>
          <div class="input-wrap">
            <i class="bi bi-lock"></i>
            <input type="password" name="password" class="form-input" placeholder="Minimum 6 caractères" required minlength="6" />
          </div>
        </div>
        <button type="submit" class="btn-submit">Créer mon compte <i class="bi bi-arrow-right"></i></button>
      </form>
      <p class="hint">Déjà inscrit ? <a href="/login">Se connecter</a></p>
    <% } %>
  </div>
</div>
</body>
</html>
